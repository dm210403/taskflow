# Database (Postgres - use Neon, Supabase, or local Docker)
DATABASE_URL="postgresql://user:password@localhost:5432/taskflow?schema=public"

# Better Auth
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
